{
  "name": "gridgame",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "node --test",
    "typecheck": "tsc -p tsconfig.json && tsc -p tsconfig.ui.json",
    "validate": "npm test && npm run typecheck",
    "dev": "concurrently -k -n azurite,swa,party -c blue,green,magenta \"npm:dev:azurite\" \"swa start ./ --api-location ./api\" \"npm:dev:party\"",
    "dev:swa": "concurrently -k -n azurite,swa -c blue,green \"npm:dev:azurite\" \"swa start ./ --api-location ./api\"",
    "dev:azurite": "azurite --silent --location ./.azurite --skipApiVersionCheck",
    "dev:api": "cd api && func start",
    "dev:party": "partykit dev",
    "party:deploy": "partykit deploy",
    "build:minify": "node scripts/minify.mjs",
    "catalog:pull": "node scripts/catalog-pull.mjs",
    "catalog:push": "node scripts/catalog-push.mjs"
  },
  "devDependencies": {
    "@azure/static-web-apps-cli": "^2.0.9",
    "@azure/storage-blob": "^12.32.0",
    "@types/node": "^25.9.1",
    "azurite": "^3.34.0",
    "concurrently": "^9.2.1",
    "esbuild": "^0.21.5",
    "partykit": "^0.0.114",
    "typescript": "^6.0.3"
  }
}
