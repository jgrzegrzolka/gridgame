  "include": [
    "flags/**/*.js",
    "party/ticTacToeServer.js",
    "party/ticTacToeServer.test.js",
    "ticTacToe/onlineClient.js",
    "ticTacToe/onlineClient.test.js",
    "common.js",
    "common.test.js",
    "confetti.js",
    "confetti.test.js",
    "colorCountPicker.js",
    "colorCountPicker.test.js",
    "i18n.js",
    "i18n.test.js"
  ]
}
